{
  "name": "whatsupdog",
  "version": "1.0.0",
  "description": "This project is for learning purposes",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "test": "test",
    "start": "node server.js",
    "dev": "nodemon -r dotenv/config server.js dotenv_config_path=whatsupdog-env/.env",
    "dev:js": "npx esbuild frontend/alpine.js --outfile=public/main.js --bundle",
    "/dev:css": "npx tailwindcss -i ./frontend/tailwind.css -o ./public/main.css -m",
    "dev:css": "npx tailwindcss -o ./public/main.css -m",
    "ssl": "openssl req -nodes -new -x509 -keyout server.key -out server.cert"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vihrogon/whatsupdog.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/Vihrogon/whatsupdog/issues"
  },
  "homepage": "https://github.com/Vihrogon/whatsupdog#readme",
  "devDependencies": {
    "nodemon": "^2.0.13",
    "tailwindcss": "^3.0.23"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.0.0",
    "express": "^4.17.3",
    "express-session": "^1.17.2",
    "express-validator": "^6.14.0",
    "helmet": "^4.6.0",
    "node-sql-wasm": "^1.0.3"
  }
}
